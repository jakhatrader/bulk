# ===== Proof of BULKTRADE — configuration =====
# 1) Get an API key at https://twitterapi.io (sign up, copy the key from the dashboard)
TWITTERAPI_KEY=your_twitterapi_io_key_here

# Port the server listens on (most hosts set this automatically)
PORT=3000

# ===== Persistent history store (FREE) =====
# The site indexes the full tweet history ONCE and then only fetches new tweets.
# To keep that history alive across restarts/redeploys on a free host (Render free
# tier wipes the disk), store it in Upstash Redis (free tier).
# Create a free DB at https://upstash.com -> Redis -> copy these two from the
# "REST API" section of the database page:
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here
# (Optional) key prefix used inside Redis
# STORE_KEY=bt:index

# How often NEW tweets are pulled in. This number is shown on the site itself.
UPDATE_INTERVAL_HOURS=24

# History floor. LEAVE EMPTY to index everything back to the FIRST BulkTrade tweet
# (i.e. from @bulktrade's first post). Or set a date like 2024-01-01 to limit it.
SINCE_DATE=

# Backfill speed/cost controls. Each page ≈ 20 tweets.
# Pages pulled per backfill chunk (chunks run back-to-back until history is complete).
BACKFILL_PAGES_PER_RUN=50
# How often (ms) to run a backfill chunk while history is still filling in.
BACKFILL_INTERVAL_MS=15000
# Safety cap for the daily "new tweets" fetch.
INCREMENTAL_MAX_PAGES=40

# How many top users to return, and how many posts to keep per profile.
TOP_LIMIT=2000
POSTS_PER_USER=25

# What counts as a BulkTrade mention (Twitter advanced-search syntax).
QUERY_TERMS=(bulktrade OR @bulktrade OR $BULK)

# Handles to exclude from the leaderboard/stats (comma-separated). The project's own
# account is excluded by default so it doesn't show up in the rankings.
EXCLUDE_HANDLES=bulktrade
